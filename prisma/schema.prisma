
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model user {
  id                  String            @id @default(uuid())
  email               String            @unique
  name                String?
  picture             String?
  credits             Int               @default(0)
  plan                String?
  created_at          DateTime          @default(now())
  subscription_id     String?
  subscription_status String?
  stripe_customer_id  String?
  generation_stats    generation_stat[]
  payment_history     payment_history[]
  posts               post[]
}

model processed_session {
  session_id   String   @id
  processed_at DateTime @default(now())
}

model payment_history {
  id                String   @id @default(uuid())
  user_id           String
  amount            Float?
  plan              String?
  credits           Int?
  stripe_session_id String?
  created_at        DateTime @default(now())
  user              user     @relation(fields: [user_id], references: [id])
}

model generation_stat {
  id                String          @id @default(uuid())
  user_id           String
  type              generation_type
  count             Int             @default(0)
  last_generated_at DateTime        @default(now())
  user              user            @relation(fields: [user_id], references: [id])
}

enum generation_type {
  video
  story
  text
  image
}

model post {
  id          String   @id @default(uuid())
  user_id     String
  prompt      String
  type        String   // text, image, video, story, etc.
  url         String   // GCP URL for image/video
  storyText   String?  // Generated text for text/story posts
  created_at  DateTime @default(now())
  user        user     @relation(fields: [user_id], references: [id])
}